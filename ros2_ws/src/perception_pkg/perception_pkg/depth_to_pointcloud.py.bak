#!/usr/bin/env python3

import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image, CameraInfo, PointCloud2, PointField
from geometry_msgs.msg import PoseStamped
from std_msgs.msg import Header
import numpy as np
import struct
from cv_bridge import CvBridge
from scipy.spatial.transform import Rotation


class DepthToPointCloudNode(Node):
    """
    将深度图像转换为3D点云
    订阅：
        /realsense/depth/image - 深度图像
        /realsense/depth/camera_info - 相机内参
        /true_pose - 无人机位姿
    发布：
        /camera/depth/points - 点云（世界坐标系）
    """
    
    def __init__(self):
        super().__init__('depth_to_pointcloud')
        
        # 参数
        self.declare_parameter('depth_topic', '/realsense/depth/image')
        self.declare_parameter('camera_info_topic', '/realsense/depth/camera_info')
        self.declare_parameter('output_topic', '/camera/depth/points')
        self.declare_parameter('max_depth', 10.0)
        self.declare_parameter('downsample_factor', 4)
        
        depth_topic = self.get_parameter('depth_topic').value
        info_topic = self.get_parameter('camera_info_topic').value
        output_topic = self.get_parameter('output_topic').value
        self.max_depth = self.get_parameter('max_depth').value
        self.downsample_factor = self.get_parameter('downsample_factor').value
        
        # CV Bridge用于图像转换
        self.bridge = CvBridge()
        self.camera_info = None
        self.current_pose = None
        
        # 订阅器
        self.depth_sub = self.create_subscription(Image, depth_topic, self.depth_callback, 10)
        self.info_sub = self.create_subscription(CameraInfo, info_topic, self.info_callback, 10)
        self.pose_sub = self.create_subscription(PoseStamped, '/true_pose', self.pose_callback, 10)
        
        # 发布器
        self.pointcloud_pub = self.create_publisher(PointCloud2, output_topic, 10)
        
        self.get_logger().info('深度到点云转换节点已启动')
        self.get_logger().info(f'订阅深度图像: {depth_topic}')
        self.get_logger().info(f'订阅相机信息: {info_topic}')
        self.get_logger().info(f'发布点云: {output_topic}')
    
    def info_callback(self, msg):
        if self.camera_info is None:
            self.camera_info = msg
            self.get_logger().info(f'收到相机信息 - 分辨率: {msg.width}x{msg.height}')
    
    def pose_callback(self, msg):
        if self.current_pose is None:
            self.get_logger().info('收到第一个位姿数据，开始世界坐标系转换')
        self.current_pose = msg
    
    def depth_callback(self, msg):
        if self.camera_info is None:
            self.get_logger().warn('等待相机信息...', throttle_duration_sec=2.0)
            return
        
        try:
            depth_image = self.bridge.imgmsg_to_cv2(msg, desired_encoding='passthrough')
            depth_array = depth_image.astype(np.float32) / 1000.0
            
            fx = self.camera_info.k[0]
            fy = self.camera_info.k[4]
            cx = self.camera_info.k[2]
            cy = self.camera_info.k[5]
            
            points = self.depth_to_points(depth_array, fx, fy, cx, cy)
            
            # 使用相机自己的坐标系，让TF系统处理转换
            # 注意：如果需要world坐标系，必须正确处理camera到body的transform
            frame_id = msg.header.frame_id  # Quadrotor/Sensors/DepthCamera
            
            header = Header()
            header.stamp = msg.header.stamp
            header.frame_id = frame_id
            pointcloud_msg = self.create_pointcloud2(points, header)
            self.pointcloud_pub.publish(pointcloud_msg)
            
        except Exception as e:
            self.get_logger().error(f'处理深度图像时出错: {str(e)}')
    
    def depth_to_points(self, depth_array, fx, fy, cx, cy):
        height, width = depth_array.shape
        step = self.downsample_factor
        u_coords, v_coords = np.meshgrid(np.arange(0, width, step), np.arange(0, height, step))
        depth_array = depth_array[::step, ::step]
        
        valid_mask = (depth_array > 0) & (depth_array < self.max_depth)
        u = u_coords[valid_mask]
        v = v_coords[valid_mask]
        z = depth_array[valid_mask]
        
        x = (u - cx) * z / fx
        y = (v - cy) * z / fy
        points = np.stack([x, y, z], axis=-1)
        return points
    
    def transform_to_world(self, points, pose_msg):
        position = np.array([pose_msg.pose.position.x, pose_msg.pose.position.y, pose_msg.pose.position.z])
        quaternion = np.array([pose_msg.pose.orientation.x, pose_msg.pose.orientation.y, 
                               pose_msg.pose.orientation.z, pose_msg.pose.orientation.w])
        rotation = Rotation.from_quat(quaternion)
        rotation_matrix = rotation.as_matrix()
        points_world = points @ rotation_matrix.T + position
        return points_world
    
    def create_pointcloud2(self, points, header):
        fields = [
            PointField(name='x', offset=0, datatype=PointField.FLOAT32, count=1),
            PointField(name='y', offset=4, datatype=PointField.FLOAT32, count=1),
            PointField(name='z', offset=8, datatype=PointField.FLOAT32, count=1),
        ]
        cloud_msg = PointCloud2()
        cloud_msg.header = header
        cloud_msg.height = 1
        cloud_msg.width = len(points)
        cloud_msg.is_dense = False
        cloud_msg.is_bigendian = False
        cloud_msg.fields = fields
        cloud_msg.point_step = 12
        cloud_msg.row_step = cloud_msg.point_step * cloud_msg.width
        buffer = [struct.pack('fff', point[0], point[1], point[2]) for point in points]
        cloud_msg.data = b''.join(buffer)
        return cloud_msg


def main(args=None):
    rclpy.init(args=args)
    node = DepthToPointCloudNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
